# ===========================================================================
# DormDrop environment variables
# Copy to `.env.local` and fill in. NEXT_PUBLIC_* values are exposed to the
# browser; everything else is server-only — never prefix a secret with
# NEXT_PUBLIC_.
# ===========================================================================

# --- Supabase (Project Settings → API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only. Used by the Stripe webhook + the runner
# "release" path to bypass RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Developers → API keys) ----------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…). From the Stripe Dashboard webhook config,
# or printed by `stripe listen` in local dev.
STRIPE_WEBHOOK_SECRET=

# --- App -------------------------------------------------------------------
# Public base URL, used for Stripe success/cancel redirects + metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Maps -----------------------------------------------------------
# Powers the landing-page delivery-zone map and the checkout address
# autocomplete. Get a key at: Google Cloud Console → APIs & Services →
# Credentials → Create credentials → API key. Then under APIs & Services →
# Library, enable: Maps JavaScript API, Places API, Geocoding API, and
# Directions API. Restrict the key to your domains (HTTP referrers).
# If unset, maps show a placeholder and the address field is a plain input.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Optional: "Report a problem" email notifications ----------------------
# If both are set, /api/report also emails the team via Resend
# (https://resend.com). If unset, reports are still stored in the DB.
RESEND_API_KEY=
REPORT_EMAIL_TO=

# --- Optional: direct DB connection for `npm run migrate` ------------------
# Only needed if you apply migrations with the script instead of pasting
# scripts/full-migration.sql into the Supabase SQL Editor. Supabase → Project
# Settings → Database → Connection string (URI), with your DB password.
SUPABASE_DB_URL=

# ---------------------------------------------------------------------------
# Local dev note: orders are created as `awaiting_payment` and only become
# `pending` (visible to runners) when the Stripe webhook fires. Forward events
# to your local server so payments complete end-to-end:
#
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
#
# Copy the printed whsec_… into STRIPE_WEBHOOK_SECRET.
# ---------------------------------------------------------------------------
